# Maintainer: zlicdt <xkicdt1@gmail.com>
# Contributor: YUCLing <luotianyi at luotianyi dot me>

pkgname=open-orpheus
pkgver=0.12.2
pkgrel=1
pkgdesc="An open-source implementation of Netease Cloud Music's Orpheus browser host."
arch=(
  'x86_64'
  'aarch64'
)
url="https://github.com/YUCLing/open-orpheus"
license=('MIT')
depends=(
  'alsa-lib'
  'gtk3'
  'nss'
  'xdg-utils'
)
makedepends=('corepack' 'nodejs')
source=("source.tar.gz::https://github.com/YUCLing/open-orpheus/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('7dedb4800dc063d3cba8ce067784e0d5607d5cafdf264becd322ca46671ad4e3')

build() {
  cd "$srcdir/${pkgname}-${pkgver}"

  mkdir -p "$srcdir/bin"
  corepack enable --install-directory "$srcdir/bin"
  export PATH="$srcdir/bin:$PATH"

  pnpm i --frozen-lockfile
  pnpm build:modules
  pnpm package
}

package() {
  cd "$srcdir/${pkgname}-${pkgver}"

  shopt -s nullglob
  builddirs=("$PWD/out/${pkgname}-linux-"*)
  shopt -u nullglob

  if [ ${#builddirs[@]} -eq 0 ]; then
    echo "Could not find built Electron app at $PWD/out/${pkgname}-linux-*"
    return 1
  fi

  builddir="${builddirs[0]}"
  if [ ${#builddirs[@]} -gt 1 ]; then
    echo "Warning: multiple build directories found; using $builddir" >&2
  fi

  mkdir -p "$pkgdir"
  node scripts/install-aur-scaffolding.mts "$builddir" "$pkgdir"
}
