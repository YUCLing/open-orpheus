# Maintainer: YUCLing <luotianyi at luotianyi dot me>

_electronversion=42

pkgname=open-orpheus
pkgver=0.12.2
pkgrel=1
pkgdesc="An open-source implementation of Netease Cloud Music's Orpheus browser host."
arch=(
  'x86_64'
  'aarch64'
)
url="https://github.com/YUCLing/open-orpheus"
license=('MIT')
depends=(
  "electron${_electronversion}"
)
makedepends=('libarchive')
source_x86_64=("${pkgname}_${pkgver}_amd64.deb::https://github.com/YUCLing/open-orpheus/releases/download/v${pkgver}/${pkgname}_${pkgver}_amd64.deb")
source_aarch64=("${pkgname}_${pkgver}_arm64.deb::https://github.com/YUCLing/open-orpheus/releases/download/v${pkgver}/${pkgname}_${pkgver}_arm64.deb")
sha256sums_x86_64=('c26b2d2b24a442768ef944c144d31d4df9deb6e43f06dfd5b1e5e693a6957e82')
sha256sums_aarch64=('95a013f34f717f5fe685aeacf782c37819ad5347947870fdc319238262200e91')

prepare() {
  case "$CARCH" in
    x86_64) ar x ${pkgname}_${pkgver}_amd64.deb ;;
    aarch64) ar x ${pkgname}_${pkgver}_arm64.deb ;;
  esac
}

package() {
  cd ${srcdir}
  bsdtar -xf data.tar.zst -C ${pkgdir} --no-same-owner
  install -Dm644 ../LICENSE "${pkgdir}/usr/share/licenses/%{pkgname}/LICENSE"
}
