{
  "compilerOptions": {
    "target": "ESNext",
    "module": "preserve",
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "outDir": "dist",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["vite/client"],
    "paths": {
      "$sharedTypes/*": ["./types/*"]
    }
  },
  "include": [
    "src",
    "forge.env.d.ts",
    "packaging/**/*.ts",
    "scripts/*.mts",
    "scripts/*.ts",
    "types/*.ts"
  ],
  "exclude": ["gui"]
}
